+const listConfigurations = `-- name: ListConfigurations :many
+SELECT ID, ConfigName, ConfigType, RxName, TxName, TpName, PayloadName, TSMConfigurationName, CortexIFM, IntermediateFrequency, ProgrammableAttnUsed, DeviceProfileName FROM "Configurations"
+`
+
+func (q *Queries) ListConfigurations(ctx context.Context) ([]Configuration, error) {
+	rows, err := q.db.QueryContext(ctx, listConfigurations)
+	if err != nil {
+		return nil, err
+	}
+	defer rows.Close()
+	var items []Configuration
+	for rows.Next() {
+		var i Configuration
+		if err := rows.Scan(
+			&i.ID,
+			&i.ConfigName,
+			&i.ConfigType,
+			&i.RxName,
+			&i.TxName,
+			&i.TpName,
+			&i.PayloadName,
+			&i.TSMConfigurationName,
+			&i.CortexIFM,
+			&i.IntermediateFrequency,
+			&i.ProgrammableAttnUsed,
+			&i.DeviceProfileName,
+		); err != nil {
+			return nil, err
+		}
+		items = append(items, i)
+	}
+	if err := rows.Close(); err != nil {
+		return nil, err
+	}
+	if err := rows.Err(); err != nil {
+		return nil, err
+	}
+	return items, nil
+}
